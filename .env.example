DATABASE_URL=postgresql://user:password@host/database?sslmode=require
ANTHROPIC_API_KEY=sk-ant-...

# Magic-link auth (U4). Resend API key required to send sign-in emails.
# Verify a sending domain at https://resend.com/domains, then set RESEND_FROM
# to a verified address.
RESEND_API_KEY=
RESEND_FROM=Robotropes <hello@robotropes.dxn.is>
NEXT_PUBLIC_APP_URL=https://robotropes.dxn.is

# Daily-spend cap (U2). When exceeded, analyzer pauses until midnight UTC.
DAILY_BUDGET_USD=5

# Free analyses per day per user/IP before AllowanceExhaustedModal fires.
FREE_ANALYSES_PER_DAY=5

# Polar.sh tip jar (U5). Values from polar.sh dashboard.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=
# Set to "sandbox" while testing; omit or set to anything else for production.
POLAR_ENV=sandbox

# Beehiiv newsletter unlock (U5). Pub ID for AI for FIs.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
