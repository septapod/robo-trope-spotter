DATABASE_URL=postgresql://user:password@host/database?sslmode=require
ANTHROPIC_API_KEY=sk-ant-...

# Magic-link auth (U4). Resend API key required to send sign-in emails.
# Verify a sending domain at https://resend.com/domains, then set RESEND_FROM
# to a verified address.
RESEND_API_KEY=
RESEND_FROM=Robotropes <hello@robotropes.dxn.is>
NEXT_PUBLIC_APP_URL=https://robotropes.dxn.is

# Daily-spend cap (U2). When exceeded, analyzer pauses until midnight UTC.
DAILY_BUDGET_USD=5
